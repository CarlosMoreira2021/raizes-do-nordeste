{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção de testes da API Raízes do Nordeste",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.collectionVariables.get('token') === undefined || pm.collectionVariables.get('token') === '') {",
          "  pm.sendRequest({",
          "    url: 'http://localhost:3000/auth/login',",
          "    method: 'POST',",
          "    header: {'Content-Type': 'application/json'},",
          "    body: {",
          "      mode: 'raw',",
          "      raw: JSON.stringify({email: 'admin@raizes.com', senha: 'Admin@123'})",
          "    }",
          "  }, function(err, res) {",
          "    var json = res.json();",
          "    pm.collectionVariables.set('token', json.accessToken);",
          "  });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "T01 - Login válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resposta = pm.response.json();",
                  "pm.collectionVariables.set('token', resposta.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@raizes.com\",\n  \"senha\": \"Admin@123\"\n}"
            },
            "url": {"raw": "http://localhost:3000/auth/login", "host": ["localhost"], "port": "3000", "path": ["auth", "login"]}
          }
        },
        {
          "name": "T02 - Login inválido",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@raizes.com\",\n  \"senha\": \"senhaerrada\"\n}"
            },
            "url": {"raw": "http://localhost:3000/auth/login", "host": ["localhost"], "port": "3000", "path": ["auth", "login"]}
          }
        },
        {
          "name": "T03 - Registrar usuário",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Teste Usuario\",\n  \"email\": \"teste2@raizes.com\",\n  \"senha\": \"Teste@123\"\n}"
            },
            "url": {"raw": "http://localhost:3000/auth/registrar", "host": ["localhost"], "port": "3000", "path": ["auth", "registrar"]}
          }
        }
      ]
    },
    {
      "name": "Erros de Autenticacao",
      "item": [
        {
          "name": "T04 - Acesso sem token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"]}
          }
        },
        {
          "name": "T05 - Token inválido (401)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer tokeninvalido123"}],
            "url": {"raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"]}
          }
        }
      ]
    },
    {
      "name": "Unidades",
      "item": [
        {
          "name": "T06 - Criar unidade (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Raízes do Nordeste - Shopping\",\n  \"endereco\": \"Av. Principal, 456\",\n  \"cidade\": \"Fortaleza\"\n}"
            },
            "url": {"raw": "http://localhost:3000/unidades", "host": ["localhost"], "port": "3000", "path": ["unidades"]}
          }
        },
        {
          "name": "T07 - Listar unidades",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:3000/unidades", "host": ["localhost"], "port": "3000", "path": ["unidades"]}
          }
        }
      ]
    },
    {
      "name": "Produtos",
      "item": [
        {
          "name": "T08 - Listar produtos",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:3000/produtos?page=1&limit=10", "host": ["localhost"], "port": "3000", "path": ["produtos"], "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "10"}]}
          }
        },
        {
          "name": "T09 - Criar produto (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Tapioca Nordestina\",\n  \"descricao\": \"Tapioca com queijo coalho\",\n  \"preco\": 18.90,\n  \"categoria\": \"Lanches\"\n}"
            },
            "url": {"raw": "http://localhost:3000/produtos", "host": ["localhost"], "port": "3000", "path": ["produtos"]}
          }
        },
        {
          "name": "T10 - Produto duplicado (409)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"X-Nordestino\",\n  \"descricao\": \"Produto duplicado\",\n  \"preco\": 32.90,\n  \"categoria\": \"Lanches\"\n}"
            },
            "url": {"raw": "http://localhost:3000/produtos", "host": ["localhost"], "port": "3000", "path": ["produtos"]}
          }
        }
      ]
    },
    {
      "name": "Estoque",
      "item": [
        {
          "name": "T11 - Entrada de estoque",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"produtoId\": 1,\n  \"quantidade\": 10,\n  \"tipo\": \"ENTRADA\"\n}"
            },
            "url": {"raw": "http://localhost:3000/estoque/movimentar", "host": ["localhost"], "port": "3000", "path": ["estoque", "movimentar"]}
          }
        },
        {
          "name": "T12 - Consultar estoque por unidade",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:3000/estoque/unidade/1", "host": ["localhost"], "port": "3000", "path": ["estoque", "unidade", "1"]}
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "T13 - Criar pedido válido (201)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    {\"produtoId\": 1, \"quantidade\": 1}\n  ]\n}"
            },
            "url": {"raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"]}
          }
        },
        {
          "name": "T14 - Canal inválido (422)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"canalPedido\": \"INVALIDO\",\n  \"itens\": [\n    {\"produtoId\": 1, \"quantidade\": 1}\n  ]\n}"
            },
            "url": {"raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"]}
          }
        },
        {
          "name": "T15 - Filtrar pedidos por canal",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:3000/pedidos?canalPedido=APP", "host": ["localhost"], "port": "3000", "path": ["pedidos"], "query": [{"key": "canalPedido", "value": "APP"}]}
          }
        },
        {
          "name": "T16 - Atualizar status do pedido",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\"\n}"
            },
            "url": {"raw": "http://localhost:3000/pedidos/1/status", "host": ["localhost"], "port": "3000", "path": ["pedidos", "1", "status"]}
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "T17 - Processar pagamento mock",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pedidoId\": 3,\n  \"formaPagamento\": \"PIX\"\n}"
            },
            "url": {"raw": "http://localhost:3000/pagamentos/processar", "host": ["localhost"], "port": "3000", "path": ["pagamentos", "processar"]}
          }
        },
        {
          "name": "T18 - Pagamento pedido inexistente (404)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pedidoId\": 9999,\n  \"formaPagamento\": \"PIX\"\n}"
            },
            "url": {"raw": "http://localhost:3000/pagamentos/processar", "host": ["localhost"], "port": "3000", "path": ["pagamentos", "processar"]}
          }
        }
      ]
    },
    {
      "name": "Fidelidade",
      "item": [
        {
          "name": "T19 - Consultar saldo de pontos",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:3000/fidelidade/meu-saldo", "host": ["localhost"], "port": "3000", "path": ["fidelidade", "meu-saldo"]}
          }
        },
        {
          "name": "T20 - Resgatar pontos insuficientes (409)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pontos\": 99999\n}"
            },
            "url": {"raw": "http://localhost:3000/fidelidade/resgatar", "host": ["localhost"], "port": "3000", "path": ["fidelidade", "resgatar"]}
          }
        }
      ]
    }
  ]
}